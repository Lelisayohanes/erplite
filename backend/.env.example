# ─────────────────────────────────────────────────────────────────────
# ERPLite – Application Configuration Reference
# ─────────────────────────────────────────────────────────────────────
#
# CONFIGURATION SOURCES (highest → lowest precedence):
#   1. Environment variables   – prefixed with ERPLITE_ (e.g. ERPLITE_APP_PORT)
#   2. .env file               – local key=value pairs read by viper
#
# IMPORTANT:
#   There are NO built-in defaults.  Every required value listed below
#   MUST be provided via the .env file or environment variables.
#   If any required value is missing the application will fail to start
#   with a clear error message.
#
# HOW IT WORKS:
#   • On startup viper reads the .env file (if present) for defaults.
#   • Existing environment variables are NOT overwritten by .env values.
#   • Environment variables (ERPLITE_*) take the highest precedence.
#   • The .env file is the primary source for local development.
#
# REQUIRED VALUES:
#   Every key listed below MUST resolve to a non-empty value.
# ─────────────────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────────────────
ERPLITE_APP_NAME=erplite          # Application name (required)
ERPLITE_APP_ENV=development       # Environment: development | staging | production (required)
ERPLITE_APP_PORT=8080             # HTTP listen port (required)
ERPLITE_APP_DEBUG=true            # Enable debug logging: true | false (required)
ERPLITE_APP_TIMEOUT=30s           # Request timeout, Go duration string (required)
ERPLITE_APP_LOGFORMAT=text        # Log output format: text | json (required)

# ── Database (PostgreSQL) ───────────────────────────────────────────
ERPLITE_DATABASE_HOST=localhost   # Database host (required)
ERPLITE_DATABASE_PORT=5432        # Database port (required)
ERPLITE_DATABASE_USER=postgres    # Database user (required)
ERPLITE_DATABASE_PASSWORD=YOUR_PASSWORD # Database password (required)
ERPLITE_DATABASE_DBNAME=erplite   # Database name (required)
ERPLITE_DATABASE_SSLMODE=disable  # SSL mode: disable | require | verify-ca | verify-full (required)
